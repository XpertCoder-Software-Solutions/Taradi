generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  EMPLOYEE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  RECEIVED
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  TEXT
  TEMPLATE
  IMAGE
  AUDIO
  VOICE
  VIDEO
  DOCUMENT
  STICKER
  INTERACTIVE
  SYSTEM
  UNKNOWN
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
  ARCHIVED
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum InvoiceStatus {
  UNPAID
  PAID
  SCHEDULED
  DISPUTED
  CANCELLED
}

enum CollectionStatus {
  ACTIVE_DEBT
  PAID
  PARTIALLY_PAID
  PROMISED_TO_PAY
  DISPUTED
  DO_NOT_CONTACT
}

enum EmployeeActivityType {
  LOGIN
  SENT_MESSAGE
  READ_CHAT
  UPDATED_CUSTOMER
  ASSIGNED_CUSTOMER
  CHANGED_CONVERSATION_STATUS
  NONE
}

enum CampaignStatus {
  DRAFT
  PREPARING
  SCHEDULED
  READY
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
  CANCELLED
}

enum CampaignRecipientStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
  CANCELLED
}

enum WhatsappAccountStatus {
  UNKNOWN
  ACTIVE
  RESTRICTED
  DISABLED
  BANNED
}

enum WhatsappQualityStatus {
  UNKNOWN
  GREEN
  YELLOW
  RED
  LOW
}

model User {
  id                                    String                          @id @default(uuid())
  email                                 String?                         @unique
  employeeCode                          String?                         @unique
  phone                                 String?                         @unique
  passwordHash                          String
  mustChangePassword                    Boolean                         @default(false)
  name                                  String
  role                                  Role                            @default(EMPLOYEE)
  supervisorId                          String?
  supervisor                            User?                           @relation("SupervisorEmployees", fields: [supervisorId], references: [id], onDelete: SetNull)
  directReports                         User[]                          @relation("SupervisorEmployees")
  isActive                              Boolean                         @default(true)
  createdCustomers                      Customer[]                      @relation("CustomerCreatedBy")
  assignedCustomers                     Customer[]                      @relation("AssignedCustomers")
  assignedConversations                 Conversation[]                  @relation("AssignedConversations")
  archivedConversations                 Conversation[]                  @relation("ConversationArchivedBy")
  previousConversationAssignments       Conversation[]                  @relation("ConversationPreviousAssignee")
  receivedConversationReassignments     Conversation[]                  @relation("ConversationReassignedTo")
  conversationReassignmentsMade         ConversationAssignmentHistory[] @relation("ConversationReassignedBy")
  previousConversationAssignmentHistory ConversationAssignmentHistory[] @relation("ConversationHistoryPreviousAssignee")
  newConversationAssignmentHistory      ConversationAssignmentHistory[] @relation("ConversationHistoryNewAssignee")
  sentMessages                          Message[]                       @relation("SentMessages")
  createdCampaigns                      Campaign[]                      @relation("CampaignCreatedBy")
  readStates                            CustomerReadState[]
  lastLoginAt                           DateTime?
  lastActivityAt                        DateTime?
  lastSeenAt                            DateTime?
  lastActivityType                      EmployeeActivityType            @default(NONE)
  createdAt                             DateTime                        @default(now())
  updatedAt                             DateTime                        @updatedAt
  userImportAuditLogs                   UserImportAuditLog[]
  campaignAuditLogs                     CampaignAuditLog[]              @relation("CampaignAuditActor")
  campaignAdminAlerts                   CampaignAdminAlert[]            @relation("CampaignAlertActor")

  @@index([supervisorId])
  @@index([role, isActive])
  @@index([supervisorId, role, isActive])
  @@index([lastActivityAt])
  @@index([lastSeenAt])
}

model UserImportAuditLog {
  id            String   @id @default(uuid())
  action        String
  actorUserId   String
  actor         User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  importedCount Int
  failedCount   Int
  fileName      String
  createdAt     DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  nameAr          String
  descriptionAr   String?
  category        String
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RolePermission {
  id            String     @id @default(uuid())
  role          Role
  permissionKey String
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade, onUpdate: Cascade)
  enabled       Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([role, permissionKey])
  @@index([permissionKey])
}

model WebhookEvent {
  id                String             @id @default(uuid())
  provider          String             @default("WHATSAPP")
  eventType         String
  whatsappMessageId String?
  payload           Json
  headers           Json?
  status            WebhookEventStatus @default(RECEIVED)
  errorMessage      String?
  processedAt       DateTime?
  createdAt         DateTime           @default(now())

  @@index([provider, eventType])
  @@index([provider, eventType, createdAt])
  @@index([status, createdAt])
  @@index([whatsappMessageId])
  @@index([whatsappMessageId, status])
}

model Customer {
  id                            String                          @id @default(uuid())
  name                          String?
  phone                         String                          @unique
  fullName                      String
  nationalId                    String?                         @unique
  accountNumber                 String                          @unique
  projectName                   String
  projectNameRaw                String?
  debtAmount                    Decimal                         @default(0) @db.Decimal(14, 2)
  serviceNumber                 String
  serviceActivationDate         DateTime?
  serviceTerminationDate        DateTime?
  invoiceStatus                 InvoiceStatus                   @default(UNPAID)
  collectionStatus              CollectionStatus                @default(ACTIVE_DEBT)
  paidAt                        DateTime?
  paidAmount                    Decimal?                        @db.Decimal(14, 2)
  paymentReference              String?
  paymentNotes                  String?
  debtYear                      Int
  source                        String                          @default("MANUAL")
  notes                         String?
  tags                          String[]                        @default([])
  whatsappProfileName           String?
  whatsappOptIn                 Boolean                         @default(false)
  whatsappOptInAt               DateTime?
  whatsappOptInSource           String?
  whatsappOptOutAt              DateTime?
  whatsappOptOutReason          String?
  whatsappOptOutMessageId       String?
  whatsappSuppressed            Boolean                         @default(false)
  whatsappSuppressionReason     String?
  lastCampaignMessageAt         DateTime?
  campaignMessageCount          Int                             @default(0)
  assignedToId                  String?
  assignedTo                    User?                           @relation("AssignedCustomers", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById                   String?
  createdBy                     User?                           @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  phones                        CustomerPhone[]
  messages                      Message[]
  conversations                 Conversation[]
  conversationAssignmentHistory ConversationAssignmentHistory[]
  readStates                    CustomerReadState[]
  debts                         CustomerDebt[]
  campaignRecipients            CampaignRecipient[]
  debtAuditLogs                 DebtAuditLog[]
  campaignAuditLogs             CampaignAuditLog[]
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt

  @@index([assignedToId])
  @@index([assignedToId, createdAt])
  @@index([assignedToId, collectionStatus, createdAt])
  @@index([phone])
  @@index([accountNumber])
  @@index([projectName])
  @@index([serviceNumber])
  @@index([invoiceStatus])
  @@index([collectionStatus])
  @@index([collectionStatus, createdAt])
  @@index([paidAt])
  @@index([debtYear])
  @@index([source])
  @@index([whatsappOptIn])
  @@index([whatsappSuppressed])
  @@index([lastCampaignMessageAt])
}

model CustomerDebt {
  id                     String              @id @default(uuid())
  customerId             String
  customer               Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  projectName            String?
  projectNameRaw         String?
  accountNumber          String
  serviceNumber          String?
  debtYear               Int
  debtAmount             Decimal             @db.Decimal(14, 2)
  invoiceStatus          InvoiceStatus?
  collectionStatus       CollectionStatus?
  serviceActivationDate  DateTime?
  serviceTerminationDate DateTime?
  paidAmount             Decimal?            @db.Decimal(14, 2)
  paidAt                 DateTime?
  paymentReference       String?
  paymentNotes           String?
  isActive               Boolean             @default(true)
  reviewRequired         Boolean             @default(false)
  reviewReason           String?
  messages               Message[]
  campaignRecipients     CampaignRecipient[]
  auditLogs              DebtAuditLog[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@unique([customerId, projectName, accountNumber, serviceNumber, debtYear])
  @@index([customerId])
  @@index([customerId, isActive])
  @@index([projectName])
  @@index([debtYear])
  @@index([accountNumber])
  @@index([serviceNumber])
  @@index([collectionStatus])
}

model DebtAuditLog {
  id         String       @id @default(uuid())
  debtId     String
  debt       CustomerDebt @relation(fields: [debtId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  actorId    String?
  action     String
  changes    Json?
  createdAt  DateTime     @default(now())

  @@index([debtId, createdAt])
  @@index([customerId, createdAt])
  @@index([actorId, createdAt])
}

model CustomerPhone {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  phoneNumber String   @unique
  isPrimary   Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([customerId, isPrimary, position])
  @@index([isPrimary])
  @@index([position])
}

model Message {
  id                          String           @id @default(uuid())
  customerId                  String
  customer                    Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  campaignId                  String?
  campaign                    Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  debtId                      String?
  debt                        CustomerDebt?    @relation(fields: [debtId], references: [id], onDelete: SetNull)
  conversationId              String?
  conversation                Conversation?    @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: SetNull)
  direction                   MessageDirection
  type                        MessageType      @default(TEXT)
  content                     String?
  body                        String?
  mediaUrl                    String?
  mediaId                     String?
  mimeType                    String?
  fileName                    String?
  fileSize                    Int?
  caption                     String?
  duration                    Int?
  templateName                String?
  whatsappMessageId           String?          @unique
  status                      MessageStatus    @default(QUEUED)
  statusUpdatedAt             DateTime?
  sentByUserId                String?
  sentByUser                  User?            @relation("SentMessages", fields: [sentByUserId], references: [id], onDelete: SetNull)
  rawPayload                  Json?
  error                       String?
  lastMessageForConversations Conversation[]   @relation("ConversationLastMessage")
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt

  @@index([customerId, createdAt])
  @@index([campaignId])
  @@index([campaignId, status])
  @@index([debtId])
  @@index([conversationId, createdAt])
  @@index([direction, status])
  @@index([status, statusUpdatedAt])
  @@index([whatsappMessageId])
  @@index([mediaId])
}

model Campaign {
  id                  String               @id @default(uuid())
  idempotencyKey      String?              @unique
  templateId          String?
  templateName        String
  languageCode        String
  selectionMode       String               @default("explicit")
  filters             Json?
  excludedCustomerIds String[]             @default([])
  excludedDebtIds     String[]             @default([])
  status              CampaignStatus       @default(DRAFT)
  phoneNumberId       String?
  selectedCount       Int                  @default(0)
  eligibleCount       Int                  @default(0)
  queuedCount         Int                  @default(0)
  sentCount           Int                  @default(0)
  deliveredCount      Int                  @default(0)
  readCount           Int                  @default(0)
  failedCount         Int                  @default(0)
  skippedCount        Int                  @default(0)
  pendingCount        Int                  @default(0)
  error               String?
  pauseReason         String?
  rawPayload          Json?
  createdById         String?
  createdBy           User?                @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  startedAt           DateTime?
  pausedAt            DateTime?
  preparedAt          DateTime?
  completedAt         DateTime?
  rateLimitPerMinute  Int?
  batchSize           Int?
  batchDelayMs        Int?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  messages            Message[]
  recipients          CampaignRecipient[]
  auditLogs           CampaignAuditLog[]
  adminAlerts         CampaignAdminAlert[]

  @@index([status])
  @@index([phoneNumberId, status])
  @@index([createdById])
  @@index([templateId])
  @@index([createdAt])
}

model CampaignRecipient {
  id                         String                  @id @default(uuid())
  campaignId                 String
  campaign                   Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId                 String
  customer                   Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  debtId                     String
  debt                       CustomerDebt            @relation(fields: [debtId], references: [id], onDelete: Restrict)
  phoneSnapshot              String?
  projectSnapshot            String?
  accountNumberSnapshot      String?
  serviceNumberSnapshot      String?
  debtYearSnapshot           Int?
  debtAmountSnapshot         Decimal?                @db.Decimal(14, 2)
  resolvedTemplateParameters Json?
  eligible                   Boolean                 @default(false)
  skipReason                 String?
  status                     CampaignRecipientStatus @default(PENDING)
  sendStatus                 MessageStatus           @default(QUEUED)
  messageId                  String?
  attemptCount               Int                     @default(0)
  queuedAt                   DateTime?
  sentAt                     DateTime?
  failedAt                   DateTime?
  nextAttemptAt              DateTime?
  whatsappMessageId          String?
  errorCategory              String?
  errorMessage               String?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  @@unique([campaignId, debtId])
  @@index([campaignId, eligible])
  @@index([campaignId, status])
  @@index([customerId])
  @@index([debtId])
}

model WhatsappPhoneNumber {
  id                           String                @id @default(uuid())
  phoneNumberId                String                @unique
  displayPhoneNumber           String?
  campaignsEnabled             Boolean               @default(true)
  accountStatus                WhatsappAccountStatus @default(UNKNOWN)
  qualityStatus                WhatsappQualityStatus @default(UNKNOWN)
  lastStatusCheckAt            DateTime?
  disabledReason               String?
  maxCampaignMessagesPerMinute Int?
  campaignBatchSize            Int?
  campaignBatchDelayMs         Int?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt

  @@index([campaignsEnabled, accountStatus])
}

model ApplicationSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model GlobalWhatsappSuppression {
  id              String   @id @default(uuid())
  normalizedPhone String   @unique
  reason          String?
  source          String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([normalizedPhone])
}

model CampaignAuditLog {
  id         String    @id @default(uuid())
  action     String
  actorId    String?
  actor      User?     @relation("CampaignAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  oldValue   Json?
  newValue   Json?
  reason     String?
  createdAt  DateTime  @default(now())

  @@index([campaignId, createdAt])
  @@index([customerId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model CampaignAdminAlert {
  id            String    @id @default(uuid())
  severity      String    @default("ERROR")
  category      String
  message       String
  phoneNumberId String?
  campaignId    String?
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?     @relation("CampaignAlertActor", fields: [createdById], references: [id], onDelete: SetNull)
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([phoneNumberId, resolvedAt])
  @@index([campaignId, createdAt])
}

model WhatsappTemplate {
  id               String                            @id @default(uuid())
  metaTemplateId   String?                           @unique
  name             String
  language         String
  category         String?
  status           String                            @default("UNKNOWN")
  components       Json?
  qualityScore     Json?
  rejectedReason   String?
  headerType       String?
  headerText       String?
  body             String?
  footer           String?
  buttons          Json?
  variables        Json?
  rawMetaResponse  Json?
  isActive         Boolean                           @default(true)
  lastSyncedAt     DateTime?
  variableMappings WhatsappTemplateVariableMapping[]
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt

  @@unique([name, language])
  @@index([status])
  @@index([category])
  @@index([language])
  @@index([isActive, status])
  @@index([lastSyncedAt])
}

model WhatsappTemplateVariableMapping {
  id                String           @id @default(uuid())
  templateId        String
  template          WhatsappTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  language          String
  variableKey       String
  placeholderNumber Int
  componentType     String
  buttonIndex       Int?
  source            String?
  sourceScope       String           @default("customer")
  fieldKey          String
  transformer       String?
  fallbackValue     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([templateId, language, variableKey])
  @@index([templateId])
  @@index([language])
  @@index([fieldKey])
}

model Conversation {
  id                        String                          @id @default(uuid())
  customerId                String
  activeKey                 String?                         @unique
  customer                  Customer                        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedEmployeeId        String?
  assignedEmployee          User?                           @relation("AssignedConversations", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  status                    ConversationStatus              @default(OPEN)
  lastMessageId             String?
  lastMessage               Message?                        @relation("ConversationLastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)
  lastMessageAt             DateTime?
  unreadCount               Int                             @default(0)
  priority                  ConversationPriority            @default(NORMAL)
  tags                      String[]                        @default([])
  archivedAt                DateTime?
  archivedById              String?
  archivedBy                User?                           @relation("ConversationArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  archiveReason             String?
  previousAssigneeId        String?
  previousAssignee          User?                           @relation("ConversationPreviousAssignee", fields: [previousAssigneeId], references: [id], onDelete: SetNull)
  reassignedToId            String?
  reassignedTo              User?                           @relation("ConversationReassignedTo", fields: [reassignedToId], references: [id], onDelete: SetNull)
  reassignedAt              DateTime?
  messages                  Message[]                       @relation("ConversationMessages")
  archivedAssignmentHistory ConversationAssignmentHistory[] @relation("ArchivedConversationHistory")
  activeAssignmentHistory   ConversationAssignmentHistory[] @relation("ActiveConversationHistory")
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt

  @@index([customerId])
  @@index([assignedEmployeeId])
  @@index([assignedEmployeeId, lastMessageAt])
  @@index([assignedEmployeeId, status, lastMessageAt])
  @@index([status])
  @@index([status, lastMessageAt])
  @@index([lastMessageAt])
  @@index([priority])
  @@index([archivedAt])
  @@index([previousAssigneeId])
  @@index([reassignedToId])
}

model ConversationAssignmentHistory {
  id                     String        @id @default(uuid())
  customerId             String
  customer               Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  archivedConversationId String?
  archivedConversation   Conversation? @relation("ArchivedConversationHistory", fields: [archivedConversationId], references: [id], onDelete: SetNull)
  activeConversationId   String?
  activeConversation     Conversation? @relation("ActiveConversationHistory", fields: [activeConversationId], references: [id], onDelete: SetNull)
  previousAssigneeId     String?
  previousAssignee       User?         @relation("ConversationHistoryPreviousAssignee", fields: [previousAssigneeId], references: [id], onDelete: SetNull)
  newAssigneeId          String?
  newAssignee            User?         @relation("ConversationHistoryNewAssignee", fields: [newAssigneeId], references: [id], onDelete: SetNull)
  reassignedById         String?
  reassignedBy           User?         @relation("ConversationReassignedBy", fields: [reassignedById], references: [id], onDelete: SetNull)
  reason                 String?
  createdAt              DateTime      @default(now())

  @@index([customerId, createdAt])
  @@index([archivedConversationId])
  @@index([activeConversationId])
  @@index([previousAssigneeId])
  @@index([newAssigneeId])
  @@index([reassignedById])
}

model CustomerReadState {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, userId])
  @@index([userId])
  @@index([customerId])
}
